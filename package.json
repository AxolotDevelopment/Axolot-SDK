{
  "name": "@axolot-ai/sdk",
  "version": "0.0.4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AxolotDevelopment/Axolot-SDK.git"
  },
  "description": "The AI-Native Visual Headless CMS integration for Astro. Connect layouts with WebSocket tunnels and local MCP servers.",
  "keywords": [
    "astro",
    "cms",
    "headless-cms",
    "visual-cms",
    "visual-editor",
    "mcp-server",
    "model-context-protocol",
    "ai-native",
    "astro-integration",
    "typescript"
  ],
  "bugs": {
    "url": "https://github.com/AxolotDevelopment/Axolot-SDK/issues"
  },
  "homepage": "https://github.com/AxolotDevelopment/Axolot-SDK#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./cms": {
      "types": "./dist/lib/cms.d.ts",
      "default": "./dist/lib/cms.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    }
  },
  "files": [
    "dist",
    "src/components/*.astro"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
