FROM node:22-alpine

WORKDIR /app

# Instalar ws de forma global o local para el túnel
RUN npm install ws

# Copiar el script del servidor de túneles
COPY packages/axolot-sdk/src/axolot-tunnel-server.cjs ./server.cjs

EXPOSE 8080
ENV PORT=8080
ENV TUNNEL_DOMAIN=tn.axolotcms.com

CMD ["node", "server.cjs"]
